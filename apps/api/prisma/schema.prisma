generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String            @id @default(uuid()) @db.Uuid
  email             String            @unique
  fullName          String            @map("full_name")
  phone             String?
  role              Role
  facilityId        String?           @map("facility_id") @db.Uuid
  districtId        String?           @map("district_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isActive          Boolean           @default(true) @map("is_active")
  lastLoginAt       DateTime?         @map("last_login_at") @db.Timestamptz(6)
  passwordHash      String?           @map("password_hash")
  alerts            Alert[]
  audit_logs        AuditLog[]
  resupply_requests ResupplyRequest[]
  stockEntries      StockEntry[]
  district          District?         @relation(fields: [districtId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  facility          Facility?         @relation(fields: [facilityId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

model District {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String     @unique
  region     String
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  facilities Facility[]
  officers   User[]

  @@map("districts")
}

model Facility {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  code              String            @unique
  level             FacilityLevel
  districtId        String            @map("district_id") @db.Uuid
  latitude          Float
  longitude         Float
  address           String?
  contactPhone      String?           @map("contact_phone")
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  isActive          Boolean           @default(true) @map("is_active")
  alerts            Alert[]
  district          District          @relation(fields: [districtId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resupply_requests ResupplyRequest[]
  stockEntries      StockEntry[]
  thresholds        Threshold[]
  workers           User[]

  @@map("facilities")
}

model Drug {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String       @unique
  genericName  String       @map("generic_name")
  category     DrugCategory
  unit         String
  emhsCode     String?      @map("emhs_code")
  description  String?
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  alerts       Alert[]
  stockEntries StockEntry[]
  thresholds   Threshold[]

  @@map("drugs")
}

model Threshold {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facilityId    String?   @map("facility_id") @db.Uuid
  drugId        String    @map("drug_id") @db.Uuid
  lowDays       Int       @default(14) @map("low_days")
  criticalDays  Int       @default(7) @map("critical_days")
  avgDailyUsage Float     @default(0) @map("avg_daily_usage")
  drug          Drug      @relation(fields: [drugId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  facilities    Facility? @relation(fields: [facilityId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([facilityId, drugId])
  @@map("thresholds")
}

model StockEntry {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facilityId    String      @map("facility_id") @db.Uuid
  drugId        String      @map("drug_id") @db.Uuid
  quantity      Float
  unit          String
  reportedById  String      @map("reported_by_id") @db.Uuid
  entryDate     DateTime    @default(now()) @map("entry_date") @db.Timestamptz(6)
  notes         String?
  status        StockStatus @default(ADEQUATE)
  daysRemaining Float?      @map("days_remaining")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  drug          Drug        @relation(fields: [drugId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  facility      Facility    @relation(fields: [facilityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reportedBy    User        @relation(fields: [reportedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([facilityId, drugId, entryDate], map: "idx_stock_entries_facility_drug")
  @@map("stock_entries")
}

model Alert {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facilityId   String      @map("facility_id") @db.Uuid
  drugId       String?     @map("drug_id") @db.Uuid
  drugName     String      @map("drug_name")
  severity     Severity
  type         AlertType
  message      String
  status       AlertStatus @default(ACTIVE)
  resolvedAt   DateTime?   @map("resolved_at") @db.Timestamptz(6)
  resolvedById String?     @map("resolved_by_id") @db.Uuid
  smsDelivered Boolean     @default(false) @map("sms_delivered")
  smsSentAt    DateTime?   @map("sms_sent_at") @db.Timestamptz(6)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  drugs        Drug?       @relation(fields: [drugId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  facility     Facility    @relation(fields: [facilityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users        User?       @relation(fields: [resolvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sms_logs     SmsLog[]

  @@index([facilityId, status, createdAt], map: "idx_alerts_facility_status")
  @@map("alerts")
}

model ResupplyRequest {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  facilityId    String   @map("facility_id") @db.Uuid
  facilityName  String   @map("facility_name")
  districtName  String   @map("district_name")
  generatedAt   DateTime @default(now()) @map("generated_at") @db.Timestamptz(6)
  requestedById String   @map("requested_by_id") @db.Uuid
  status        String   @default("PENDING")
  items         Json
  pdfUrl        String?  @map("pdf_url")
  facilities    Facility @relation(fields: [facilityId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         User     @relation(fields: [requestedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("resupply_requests")
}

model SmsLog {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recipient   String
  message     String
  status      String
  alertId     String?   @map("alert_id") @db.Uuid
  provider    String    @default("AfricasTalking")
  sentAt      DateTime  @default(now()) @map("sent_at") @db.Timestamptz(6)
  deliveredAt DateTime? @map("delivered_at") @db.Timestamptz(6)
  alerts      Alert?    @relation(fields: [alertId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("sms_logs")
}

model AuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String
  entity    String
  entityId  String?  @map("entity_id") @db.Uuid
  before    Json?
  after     Json?
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  users     User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("audit_logs")
}

enum Role {
  FACILITY_WORKER
  DISTRICT_OFFICER
  NMS_ADMIN
  SUPER_ADMIN

  @@map("role")
}

enum FacilityLevel {
  HC_II
  HC_III
  HC_IV
  GENERAL_HOSPITAL
  REGIONAL_REFERRAL

  @@map("facility_level")
}

enum DrugCategory {
  ANTIBIOTIC
  ANTIMALARIAL
  ARV
  ANALGESIC
  ANTIHYPERTENSIVE
  ANTIDIABETIC
  VACCINE
  MATERNAL_HEALTH
  SURGICAL_SUPPLY
  DIAGNOSTIC
  OTHER

  @@map("drug_category")
}

enum StockStatus {
  ADEQUATE
  LOW
  CRITICAL
  STOCKOUT

  @@map("stock_status")
}

enum Severity {
  INFO
  WARNING
  CRITICAL

  @@map("severity")
}

enum AlertType {
  STOCK_LOW
  STOCK_CRITICAL
  STOCKOUT
  STOCK_EXPIRING
  SYSTEM

  @@map("alert_type")
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  DISMISSED

  @@map("alert_status")
}

enum public_AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  DISMISSED

  @@map("AlertStatus")
}

enum public_AlertType {
  STOCK_LOW
  STOCK_CRITICAL
  STOCKOUT
  STOCK_EXPIRING
  SYSTEM

  @@map("AlertType")
}

enum public_DrugCategory {
  ANTIBIOTIC
  ANTIMALARIAL
  ARV
  ANALGESIC
  ANTIHYPERTENSIVE
  ANTIDIABETIC
  VACCINE
  MATERNAL_HEALTH
  SURGICAL_SUPPLY
  DIAGNOSTIC
  OTHER

  @@map("DrugCategory")
}

enum public_FacilityLevel {
  HC_II
  HC_III
  HC_IV
  GENERAL_HOSPITAL
  REGIONAL_REFERRAL

  @@map("FacilityLevel")
}

enum public_Role {
  FACILITY_WORKER
  DISTRICT_OFFICER
  NMS_ADMIN
  SUPER_ADMIN

  @@map("Role")
}

enum public_Severity {
  INFO
  WARNING
  CRITICAL

  @@map("Severity")
}

enum public_StockStatus {
  ADEQUATE
  LOW
  CRITICAL
  STOCKOUT

  @@map("StockStatus")
}
